	pt box:
		left: 273
		top: 466
		width: 81
		height:	42
		z index: 1
		visible: { card.pt != "" }
		render style: image
		image: { card_ptbox() }
	foil layer:
		left: 0
		top : 0
		width: 375
		height: 523
		z index: 1050
		render style: image
